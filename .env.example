# Playwright Executor Configuration
PORT=8932

# Available browsers (comma-separated list)
# Testers can select from these browsers when running tests
#
# Valid identifiers:
#   - chromium, chromium-headless (Playwright's bundled Chromium)
#   - chrome, chrome-headless (requires Google Chrome installed)
#   - firefox, firefox-headless (Playwright's bundled Firefox)
#   - webkit, webkit-headless (Playwright's bundled WebKit/Safari)
#
# Examples:
#   Local development: AVAILABLE_BROWSERS=chrome-headless,chrome,firefox-headless,firefox
#   CI/Production:     AVAILABLE_BROWSERS=chromium-headless
#   Full testing:      AVAILABLE_BROWSERS=chrome-headless,chrome,firefox-headless,firefox,webkit-headless
#
# Note: First browser in list is the default
# Note: Run `uv run playwright install firefox` to install Firefox
#
AVAILABLE_BROWSERS=chromium-headless

# Default timeout for browser operations in milliseconds
BROWSER_TIMEOUT=30000
